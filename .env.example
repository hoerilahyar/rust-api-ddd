# Alternative to config/config.local.yaml -- any of these override the
# matching config.yaml key using the APP__SECTION__KEY convention.
# Copy to .env and fill in real values for local development.
APP__DATABASE__URL=postgres://postgres:postgres@localhost:5432/rust_clean_ddd
APP__REDIS__URL=redis://127.0.0.1:6379
APP__JWT__ACCESS_SECRET=change-me-access-secret
APP__JWT__REFRESH_SECRET=change-me-refresh-secret
